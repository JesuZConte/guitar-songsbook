{
  "songbook": {
    "version": "2.0",
    "lastUpdated": "2026-03-29",
    "songs": [
      {
        "id": "pd-001",
        "title": "Amazing Grace",
        "artist": "Traditional (John Newton, 1779)",
        "genre": "Folk",
        "difficulty": "beginner",
        "key": "G",
        "capo": 0,
        "chords": ["G", "C", "D"],
        "tags": ["traditional", "folk", "hymn", "public-domain"],
        "notes": "Public domain hymn. Simple 3-chord structure, great for beginners.",
        "content": [
          {
            "type": "verse",
            "number": 1,
            "lines": [
              {
                "text": "Amazing grace how sweet the sound",
                "chords": [
                  { "chord": "G", "position": 0 },
                  { "chord": "C", "position": 15 }
                ]
              },
              {
                "text": "That saved a wretch like me",
                "chords": [
                  { "chord": "G", "position": 0 },
                  { "chord": "D", "position": 20 }
                ]
              },
              {
                "text": "I once was lost but now am found",
                "chords": [
                  { "chord": "G", "position": 0 },
                  { "chord": "C", "position": 18 }
                ]
              },
              {
                "text": "Was blind but now I see",
                "chords": [
                  { "chord": "D", "position": 0 },
                  { "chord": "G", "position": 14 }
                ]
              }
            ]
          },
          {
            "type": "verse",
            "number": 2,
            "lines": [
              {
                "text": "Twas grace that taught my heart to fear",
                "chords": [
                  { "chord": "G", "position": 0 },
                  { "chord": "C", "position": 24 }
                ]
              },
              {
                "text": "And grace my fears relieved",
                "chords": [
                  { "chord": "G", "position": 0 },
                  { "chord": "D", "position": 15 }
                ]
              },
              {
                "text": "How precious did that grace appear",
                "chords": [
                  { "chord": "G", "position": 0 },
                  { "chord": "C", "position": 20 }
                ]
              },
              {
                "text": "The hour I first believed",
                "chords": [
                  { "chord": "D", "position": 0 },
                  { "chord": "G", "position": 14 }
                ]
              }
            ]
          }
        ]
      },
      {
        "id": "pd-002",
        "title": "Greensleeves",
        "artist": "Traditional (English, 16th century)",
        "genre": "Folk",
        "difficulty": "intermediate",
        "key": "Am",
        "capo": 0,
        "chords": ["Am", "G", "Em", "E"],
        "tags": ["traditional", "folk", "english", "fingerpicking", "public-domain"],
        "notes": "Public domain English folk song. Beautiful fingerpicking piece in Am.",
        "content": [
          {
            "type": "verse",
            "number": 1,
            "lines": [
              {
                "text": "Alas my love you do me wrong",
                "chords": [
                  { "chord": "Am", "position": 0 },
                  { "chord": "G", "position": 14 }
                ]
              },
              {
                "text": "To cast me off discourteously",
                "chords": [
                  { "chord": "Am", "position": 0 },
                  { "chord": "E", "position": 15 }
                ]
              },
              {
                "text": "For I have loved you well and long",
                "chords": [
                  { "chord": "Am", "position": 0 },
                  { "chord": "G", "position": 18 }
                ]
              },
              {
                "text": "Delighting in your company",
                "chords": [
                  { "chord": "Em", "position": 0 },
                  { "chord": "Am", "position": 14 }
                ]
              }
            ]
          },
          {
            "type": "chorus",
            "number": 1,
            "lines": [
              {
                "text": "Greensleeves was all my joy",
                "chords": [
                  { "chord": "G", "position": 0 },
                  { "chord": "Em", "position": 16 }
                ]
              },
              {
                "text": "Greensleeves was my delight",
                "chords": [
                  { "chord": "G", "position": 0 },
                  { "chord": "E", "position": 20 }
                ]
              },
              {
                "text": "Greensleeves was my heart of gold",
                "chords": [
                  { "chord": "Am", "position": 0 },
                  { "chord": "G", "position": 20 }
                ]
              },
              {
                "text": "And who but my lady Greensleeves",
                "chords": [
                  { "chord": "Em", "position": 0 },
                  { "chord": "Am", "position": 16 }
                ]
              }
            ]
          }
        ]
      },
      {
        "id": "pd-003",
        "title": "Scarborough Fair",
        "artist": "Traditional (English ballad)",
        "genre": "Folk",
        "difficulty": "intermediate",
        "key": "Am",
        "capo": 0,
        "chords": ["Am", "G", "C", "D"],
        "tags": ["traditional", "folk", "english", "ballad", "public-domain"],
        "notes": "Public domain medieval English ballad. The arrangement popularized in the 1960s.",
        "content": [
          {
            "type": "verse",
            "number": 1,
            "lines": [
              {
                "text": "Are you going to Scarborough Fair",
                "chords": [
                  { "chord": "Am", "position": 0 },
                  { "chord": "G", "position": 20 }
                ]
              },
              {
                "text": "Parsley sage rosemary and thyme",
                "chords": [
                  { "chord": "Am", "position": 0 },
                  { "chord": "C", "position": 12 },
                  { "chord": "Am", "position": 28 }
                ]
              },
              {
                "text": "Remember me to one who lives there",
                "chords": [
                  { "chord": "Am", "position": 0 },
                  { "chord": "D", "position": 18 }
                ]
              },
              {
                "text": "She once was a true love of mine",
                "chords": [
                  { "chord": "Am", "position": 0 },
                  { "chord": "G", "position": 12 },
                  { "chord": "Am", "position": 26 }
                ]
              }
            ]
          },
          {
            "type": "verse",
            "number": 2,
            "lines": [
              {
                "text": "Tell her to make me a cambric shirt",
                "chords": [
                  { "chord": "Am", "position": 0 },
                  { "chord": "G", "position": 22 }
                ]
              },
              {
                "text": "Parsley sage rosemary and thyme",
                "chords": [
                  { "chord": "Am", "position": 0 },
                  { "chord": "C", "position": 12 },
                  { "chord": "Am", "position": 28 }
                ]
              },
              {
                "text": "Without no seams nor needlework",
                "chords": [
                  { "chord": "Am", "position": 0 },
                  { "chord": "D", "position": 16 }
                ]
              },
              {
                "text": "Then she will be a true love of mine",
                "chords": [
                  { "chord": "Am", "position": 0 },
                  { "chord": "G", "position": 14 },
                  { "chord": "Am", "position": 30 }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}
